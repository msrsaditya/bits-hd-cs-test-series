<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
</head>
<body style="background:#121212; color:#E0E0E0; display:flex; justify-content:center; align-items:center; height:100vh;">
<div class="card p-4 shadow-lg" style="background:#1E1E2D; border-radius:1rem; width:420px; text-align:center; color:#E0E0E0; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
    <h3 style="font-weight:300; letter-spacing:1px;">BITS HD CS</h3>
    <h5 style="margin-bottom:1.5rem; color:#adb5bd;">Test Series</h5>
    <% if (mode === 'login') { %>
        <form action="/login" method="POST">
            <div class="mb-3"><input type="text" name="username" class="form-control" placeholder="Username" required style="background:#2a2a3a; border:1px solid #3a3a4a; color:#E0E0E0;"></div>
            <div class="mb-3"><input type="password" name="password" class="form-control" placeholder="Password" required style="background:#2a2a3a; border:1px solid #3a3a4a; color:#E0E0E0;"></div>
            <button type="submit" class="btn btn-primary w-100" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border:none; font-weight:600;">Login</button>
        </form>
        <p class="mt-3" style="font-size:0.9rem;">Don't have an account? <a href="/signup" style="color:#667eea;">Sign up</a></p>
    <% } else { %>
        <form action="/signup" method="POST">
            <div class="mb-3"><input type="text" name="username" class="form-control" placeholder="Username" required style="background:#2a2a3a; border:1px solid #3a3a4a; color:#E0E0E0;"></div>
            <div class="mb-3"><input type="password" name="password" class="form-control" placeholder="Password" required style="background:#2a2a3a; border:1px solid #3a3a4a; color:#E0E0E0;"></div>
            <div class="mb-3"><input type="password" name="confirm_password" class="form-control" placeholder="Confirm Password" required style="background:#2a2a3a; border:1px solid #3a3a4a; color:#E0E0E0;"></div>
            <button type="submit" class="btn btn-success w-100" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); border:none; font-weight:600; color:#121212;">Sign Up</button>
        </form>
        <p class="mt-3" style="font-size:0.9rem;">Already have an account? <a href="/login" style="color:#667eea;">Log in</a></p>
    <% } %>
    <% if (error) { %><div class="alert alert-danger mt-3"><%= error %></div><% } %>
    <% if (success) { %><div class="alert alert-success mt-3"><%= success %></div><% } %>
</div>
</body>
</html>
