<script>
// MathJax compatibility shim – webapp.js calls MathJax.Hub.Queue(["Typeset", ...])
// Calls made before KaTeX loads (defer) are queued and flushed once KaTeX is ready.
window.MathJax = (function() {
    var _queue = [];
    var _ready = false;
    var _opts = {
        delimiters: [
            {left: '$$', right: '$$', display: true},
            {left: '$',  right: '$',  display: false},
            {left: '\\(', right: '\\)', display: false},
            {left: '\\[', right: '\\]', display: true}
        ],
        throwOnError: false
    };

    // Decode HTML inside LaTeX: <br> → newline, strip tags, decode entities
    function _texFromHtml(html) {
        var s = html.replace(/<br\s*\/?>/gi, '\n')
                    .replace(/<\/p>/gi, '\n')
                    .replace(/<\/div>/gi, '\n');
        var tmp = document.createElement('span');
        tmp.innerHTML = s;
        return tmp.textContent || tmp.innerText || '';
    }

    // Pre-process innerHTML for display math that may span HTML elements.
    // KaTeX auto-render only sees individual text nodes, so \[...\] or bare
    // \begin{env}...\end{env} split across <p>/<br> tags won't match.
    // We handle these via innerHTML regex + katex.renderToString first.
    function _preprocessDisplayMath(el) {
        if (typeof katex === 'undefined') return;
        var html = el.innerHTML;
        var orig = html;
        var _annots = [];
        function _protect(h) {
            return h.replace(/<annotation[^>]*>[\s\S]*?<\/annotation>/g, function(m) {
                _annots.push(m); return '<!--KA:' + (_annots.length - 1) + '-->';
            });
        }

        // Convert \[...\] to $$...$$ so existing handler picks it up
        // Negative lookbehind: skip \\[1em] etc. (line-break spacing args)
        html = html.replace(/(?<!\\)\\\[/g, '$$$$').replace(/(?<!\\)\\\]/g, '$$$$');

        // $$...$$ display math (non-greedy, may span HTML tags)
        html = html.replace(/\$\$([\s\S]*?)\$\$/g, function(m, tex) {
            try { return katex.renderToString(_texFromHtml(tex), {displayMode: true, throwOnError: false}); }
            catch(e) { return m; }
        });
        html = _protect(html);

        // $...$ inline math containing \begin{env} (spans HTML tags).
        html = html.replace(/\$([^$]*?\\begin\{[^$]*?)\$/g, function(m, tex) {
            try { return katex.renderToString(_texFromHtml(tex), {displayMode: false, throwOnError: false}); }
            catch(e) { return m; }
        });
        html = _protect(html);

        // bare \begin{env}...\end{env} (not already rendered above)
        html = html.replace(/\\begin\{([^}]+)\}([\s\S]*?)\\end\{\1\}/g, function(m, env, inner) {
            try {
                var tex = '\\begin{' + env + '}' + _texFromHtml(inner) + '\\end{' + env + '}';
                return katex.renderToString(tex, {displayMode: true, throwOnError: false});
            } catch(e) { return m; }
        });

        // Restore all protected annotations
        html = html.replace(/<!--KA:(\d+)-->/g, function(m, i) {
            return _annots[parseInt(i)];
        });

        if (html !== orig) el.innerHTML = html;
    }

    function _fixTextUnderscores(tex) {
        var re = /\\text(?:bf|it|rm|sf|tt|normal)?\s*\{/g;
        var result = '', i = 0, m;
        while ((m = re.exec(tex)) !== null) {
            var cmd = m[0];
            result += tex.substring(i, m.index);
            var start = m.index + cmd.length, braces = 1, j = start;
            while (j < tex.length && braces > 0) {
                if (tex[j] === '{') braces++;
                else if (tex[j] === '}') braces--;
                if (braces > 0) j++;
            }
            var inner = tex.substring(start, j);
            /* Split on unescaped $ to find nested math */
            var parts = [], last = 0, ci;
            for (ci = 0; ci < inner.length; ci++) {
                if (inner[ci] === '$' && (ci === 0 || inner[ci-1] !== '\\')) {
                    parts.push(inner.substring(last, ci)); last = ci + 1;
                }
            }
            parts.push(inner.substring(last));
            function _escText(s) { return s.replace(/([^\\])_/g,'$1\\_').replace(/^_/,'\\_').replace(/([^\\])#/g,'$1\\#').replace(/^#/,'\\#'); }
            if (parts.length >= 3) {
                var rebuilt = '';
                for (var pi = 0; pi < parts.length; pi++) {
                    if (pi % 2 === 0) {
                        var t = _escText(parts[pi]);
                        if (t.length > 0 || pi === 0) rebuilt += cmd + t + '}';
                    } else {
                        rebuilt += parts[pi];
                    }
                }
                result += rebuilt;
            } else {
                result += cmd + _escText(inner) + '}';
            }
            i = j + 1; re.lastIndex = i;
        }
        return result + tex.substring(i);
    }

    function _fixArrayAtCols(tex) {
        var pat = /\\begin\{array\}\{/g;
        var result = '', lastEnd = 0, m;
        while ((m = pat.exec(tex)) !== null) {
            result += tex.substring(lastEnd, m.index) + m[0];
            var start = m.index + m[0].length, braces = 1, j = start;
            while (j < tex.length && braces > 0) {
                if (tex[j] === '{') braces++;
                else if (tex[j] === '}') braces--;
                if (braces > 0) j++;
            }
            var spec = tex.substring(start, j), cleaned = '', ci = 0;
            while (ci < spec.length) {
                if (spec[ci] === '@' && ci + 1 < spec.length && spec[ci + 1] === '{') {
                    var b = 0; ci++;
                    while (ci < spec.length) {
                        if (spec[ci] === '{') b++;
                        else if (spec[ci] === '}') { b--; if (b === 0) { ci++; break; } }
                        ci++;
                    }
                } else { cleaned += spec[ci]; ci++; }
            }
            result += cleaned.trim() + '}';
            lastEnd = j + 1; pat.lastIndex = lastEnd;
        }
        return result + tex.substring(lastEnd);
    }

    function _fixKatexCompat(tex, isDisplay) {
        /* Escape bare underscores inside \text{}, \textbf{}, etc. */
        tex = _fixTextUnderscores(tex);
        /* Strip @{...} from array/tabular column specs — unsupported in KaTeX */
        tex = _fixArrayAtCols(tex);
        /* \color{X}{Y} -> \textcolor{X}{Y} to avoid scope bleeding */
        tex = tex.replace(/\\color\s*(\{[^}]*\})\s*\{/g, '\\textcolor$1{');
        /* Remove \hline outside array/tabular environments where KaTeX forbids it */
        if (!/\\begin\{(array|tabular)\}/.test(tex)) {
            tex = tex.replace(/\\hline\b/g, '');
        }
        /* Strip optional spacing args like \\[1em], \\[3em] after line breaks */
        tex = tex.replace(/\\\\\s*\[\s*[\d.]+\s*(em|ex|pt|mm|cm|in|pc|mu)\s*\]/g, '\\\\');
        /* Strip \renewcommand{\arraystretch}{...} — unsupported in KaTeX */
        tex = tex.replace(/\\renewcommand\s*\{\s*\\arraystretch\s*\}\s*\{[^}]*\}/g, '');
        /* \tag{X} -> \qquad (X) in inline mode — KaTeX only supports \tag in display mode */
        if (!isDisplay) {
            tex = tex.replace(/\\tag\*?\s*\{([^}]*)\}/g, '\\qquad ($1)');
        }
        /* \bbox[opts]{X} -> \boxed{X} — unsupported in KaTeX */
        tex = tex.replace(/\\bbox\s*(?:\[[^\]]*\])?\s*\{/g, '\\boxed{');
        return tex;
    }

    var _katexPatched = false;
    function _patchKatex() {
        if (_katexPatched || typeof katex === 'undefined') return;
        _katexPatched = true;
        var _origRenderToString = katex.renderToString;
        katex.renderToString = function(tex, opts) {
            var disp = opts && opts.displayMode;
            return _origRenderToString.call(katex, _fixKatexCompat(tex, disp), opts);
        };
        var _origRender = katex.render;
        katex.render = function(tex, el, opts) {
            var disp = opts && opts.displayMode;
            return _origRender.call(katex, _fixKatexCompat(tex, disp), el, opts);
        };
    }

    function _render(el) {
        _patchKatex();
        var target = el || document.body;
        // Only run _preprocessDisplayMath on specific elements, never on
        // document.body — setting body.innerHTML destroys all event handlers
        // (calculator buttons, draggable, etc.).
        if (el) {
            _preprocessDisplayMath(target);
        } else {
            // No specific element: preprocess quiz-specific containers only
            ['quesContents', 'viewQPDiv', 'questionCont'].forEach(function(id) {
                var blk = document.getElementById(id);
                if (blk) _preprocessDisplayMath(blk);
            });
        }
        if (typeof renderMathInElement === 'function') {
            renderMathInElement(target, _opts);
        }
    }
    return {
        Hub: {
            Queue: function(args) {
                var el = null;
                if (args && args[2]) {
                    el = (typeof args[2] === 'string')
                        ? document.getElementById(args[2])
                        : (args[2] instanceof Element ? args[2] : null);
                }
                if (_ready) {
                    _render(el);
                } else {
                    _queue.push(el);
                }
            },
            _flush: function() {
                _ready = true;
                while (_queue.length) { _render(_queue.shift()); }
            }
        }
    };
})();
</script>

